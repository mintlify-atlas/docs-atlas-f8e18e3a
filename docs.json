{
  "$schema": "https://mintlify.com/docs.json",
  "name": "JS Beautify",
  "theme": "mint",
  "colors": {
    "primary": "#fbc826",
    "light": "#04c754",
    "dark": "#fbc826"
  },
  "favicon": "/favicon.png",
  "logo": {
    "light": "/logo.png",
    "dark": "/logo.png"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/beautifier/js-beautify"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/beautifier/js-beautify"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "installation",
              "quickstart"
            ]
          },
          {
            "group": "Usage",
            "pages": [
              "usage/node-library",
              "usage/cli",
              "usage/python",
              "usage/web-browser"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "configuration/options",
              "configuration/jsbeautifyrc",
              "configuration/editorconfig",
              "configuration/language-overrides"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/javascript-beautifier",
              "guides/css-beautifier",
              "guides/html-beautifier",
              "guides/directives"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/js-options",
              "reference/css-options",
              "reference/html-options"
            ]
          },
          {
            "group": "Contributing",
            "pages": [
              "contributing/overview",
              "contributing/changelog"
            ]
          }
        ]
      }
    ]
  }
}
